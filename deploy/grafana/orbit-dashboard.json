{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Cluster Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Peer Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_peer_count", "legendFormat": "peers" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 3 }] } }
      }
    },
    {
      "title": "Leader",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_leader_info == 1", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Active Scenario",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_scenario_active == 1", "legendFormat": "{{scenario}} ({{run_id}})" }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(orbit_app_connections_active)", "legendFormat": "connections" }
      ]
    },
    {
      "title": "Generator Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(orbit_generator_errors_total[5m]))", "legendFormat": "errors/5m" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Checksum Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(orbit_app_checksum_errors_total[5m]))", "legendFormat": "errors/5m" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Application Layer",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "App Throughput (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (source, target) (rate(orbit_app_bytes_sent_total[1m]))", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "App Bytes Received Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (source, target) (rate(orbit_app_bytes_received_total[1m]))", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "HTTP/gRPC Request Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(orbit_app_request_duration_seconds_bucket[1m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(orbit_app_request_duration_seconds_bucket[1m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(orbit_app_request_duration_seconds_bucket[1m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Packets Sent/Received Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(orbit_app_packets_sent_total[1m]))", "legendFormat": "sent/s" },
        { "refId": "B", "expr": "sum(rate(orbit_app_packets_received_total[1m]))", "legendFormat": "recv/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      }
    },
    {
      "title": "Wire Layer (TCP_INFO)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "Wire RTT",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_rtt_seconds", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Wire RTT Variance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_rtt_variance_seconds", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Wire Congestion Window",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_cwnd_segments", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Wire Retransmissions Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_wire_segments_retransmitted_total[1m])", "legendFormat": "{{source}} → {{target}}" },
        { "refId": "B", "expr": "rate(orbit_wire_lost_packets_total[1m])", "legendFormat": "lost: {{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Wire Bytes Sent/Received Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (source, target) (rate(orbit_wire_bytes_sent_total[1m]))", "legendFormat": "sent: {{source}} → {{target}}" },
        { "refId": "B", "expr": "sum by (source, target) (rate(orbit_wire_bytes_received_total[1m]))", "legendFormat": "recv: {{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Node / System",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "title": "Node Interface Bytes Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_node_ip_bytes_sent_total[1m])", "legendFormat": "tx: {{node}}/{{interface}}" },
        { "refId": "B", "expr": "rate(orbit_node_ip_bytes_received_total[1m])", "legendFormat": "rx: {{node}}/{{interface}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Node TCP Opens Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_node_tcp_active_opens_total[1m])", "legendFormat": "active: {{node}}" },
        { "refId": "B", "expr": "rate(orbit_node_tcp_passive_opens_total[1m])", "legendFormat": "passive: {{node}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Generator Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false
    },
    {
      "title": "Generator Bytes Rate by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_generator_bytes_total[1m]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Generator Errors Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_generator_errors_total[1m]))", "legendFormat": "{{flow_type}}" }
      ]
    },
    {
      "title": "Generator Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, flow_type) (rate(orbit_generator_latency_seconds_bucket[1m])))", "legendFormat": "p50 {{flow_type}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, flow_type) (rate(orbit_generator_latency_seconds_bucket[1m])))", "legendFormat": "p95 {{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Receiver Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "collapsed": false
    },
    {
      "title": "Receiver Bytes Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (receiver_type) (rate(orbit_receiver_bytes_total[1m]))", "legendFormat": "{{receiver_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Receiver Connections Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (receiver_type) (rate(orbit_receiver_connections_total[1m]))", "legendFormat": "{{receiver_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["orbit", "network", "mesh"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Orbit - Network Measurement",
  "uid": "orbit-overview",
  "version": 1
}
