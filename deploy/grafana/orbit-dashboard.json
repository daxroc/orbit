      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(orbit_app_bytes_sent_total, scenario)",
        "hide": 0,
        "includeAll": true,
        "label": "Scenario",
        "multi": true,
        "name": "scenario",
        "options": [],
        "query": "label_values(orbit_app_bytes_sent_total, scenario)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(orbit_app_bytes_sent_total, direction)",
        "hide": 0,
        "includeAll": true,
        "label": "Direction",
        "multi": true,
        "name": "direction",
        "options": [],
        "query": "label_values(orbit_app_bytes_sent_total, direction)",
        "refresh": 2,
        "regex": "",
