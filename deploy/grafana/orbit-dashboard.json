{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Cluster Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Peer Count",
      "description": "Number of discovered peers in the orbit mesh. Green (≥3) indicates a healthy quorum; yellow (1–2) may signal peer loss.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_peer_count", "legendFormat": "peers" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 3 }] } }
      }
    },
    {
      "title": "Leader",
      "description": "Instance currently holding the leader-election lease. The leader coordinates scenario distribution and mesh assignments.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_leader_info == 1", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "title": "Active Scenario",
      "description": "Currently running traffic scenario and its unique run ID. Empty when no scenario is activated.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_scenario_active == 1", "legendFormat": "{{scenario}} ({{run_id}})" }
      ]
    },
    {
      "title": "Active Connections",
      "description": "Total number of active TCP and gRPC connections across all generators cluster-wide.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(orbit_app_connections_active{scenario=~\"$scenario\", flow_type=~\"$flow_type\"})", "legendFormat": "connections" }
      ]
    },
    {
      "title": "Generator Errors",
      "description": "Total generator errors in the last 5 minutes. Non-zero values (red) indicate failures in traffic generation such as connection refused or timeouts.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[5m]))", "legendFormat": "errors/5m" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Checksum Errors",
      "description": "Payload checksum mismatches detected in the last 5 minutes. Non-zero values indicate data corruption between sender and receiver.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum(increase(orbit_app_checksum_errors_total{flow_type=~\"$flow_type\"}[5m]))", "legendFormat": "errors/5m" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Application Layer — East-West",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Bytes Sent Rate — East-West",
      "description": "Application-layer send rate for east-west (pod-to-pod) traffic, broken down by flow type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_bytes_sent_total{scenario=~\"$scenario\", direction=\"east-west\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Bytes Received Rate — East-West",
      "description": "Application-layer receive rate for east-west (pod-to-pod) traffic, broken down by flow type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_bytes_received_total{scenario=~\"$scenario\", direction=\"east-west\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Application Layer — North-South",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Bytes Sent Rate — North-South",
      "description": "Application-layer send rate for north-south (external/satellite) traffic, broken down by flow type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_bytes_sent_total{scenario=~\"$scenario\", direction=\"north-south\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Bytes Received Rate — North-South",
      "description": "Application-layer receive rate for north-south (external/satellite) traffic, broken down by flow type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_bytes_received_total{scenario=~\"$scenario\", direction=\"north-south\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Application Layer — Latency & Packets",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "HTTP/gRPC Request Latency (p50/p95/p99)",
      "description": "End-to-end request latency percentiles for HTTP and gRPC flows, broken down by flow type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, flow_type) (rate(orbit_app_request_duration_seconds_bucket{scenario=~\"$scenario\", flow_type=~\"$flow_type\"}[$__rate_interval])))", "legendFormat": "p50 {{flow_type}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, flow_type) (rate(orbit_app_request_duration_seconds_bucket{scenario=~\"$scenario\", flow_type=~\"$flow_type\"}[$__rate_interval])))", "legendFormat": "p95 {{flow_type}}" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le, flow_type) (rate(orbit_app_request_duration_seconds_bucket{scenario=~\"$scenario\", flow_type=~\"$flow_type\"}[$__rate_interval])))", "legendFormat": "p99 {{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Packets Sent/Received Rate",
      "description": "UDP/ICMP packet send and receive rates, broken down by flow type. Divergence indicates packet loss.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_packets_sent_total{scenario=~\"$scenario\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "sent {{flow_type}}" },
        { "refId": "B", "expr": "sum by (flow_type) (rate(orbit_app_packets_received_total{scenario=~\"$scenario\", flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "recv {{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      }
    },
    {
      "title": "Wire Layer (TCP_INFO)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Wire RTT",
      "description": "TCP round-trip time sourced from TCP_INFO per connection. Reflects actual kernel-measured network latency between peers.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_rtt_seconds", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Wire RTT Variance",
      "description": "Variance in TCP round-trip time from TCP_INFO. High or spiking variance indicates network jitter or route instability.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_rtt_variance_seconds", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Wire Congestion Window",
      "description": "TCP congestion window size in segments from TCP_INFO. Sudden drops indicate congestion events or packet loss triggering cwnd reduction.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "orbit_wire_cwnd_segments", "legendFormat": "{{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Wire Retransmissions Rate",
      "description": "Rate of TCP segment retransmissions and lost packets from TCP_INFO. Sustained retransmissions signal network congestion or link-layer errors.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_wire_segments_retransmitted_total[1m])", "legendFormat": "{{source}} → {{target}}" },
        { "refId": "B", "expr": "rate(orbit_wire_lost_packets_total[1m])", "legendFormat": "lost: {{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Wire Bytes Sent/Received Rate",
      "description": "Kernel-reported TCP byte rates from TCP_INFO, independent of application counters. Compare with App Throughput to measure protocol overhead.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (source, target) (rate(orbit_wire_bytes_sent_total[1m]))", "legendFormat": "sent: {{source}} → {{target}}" },
        { "refId": "B", "expr": "sum by (source, target) (rate(orbit_wire_bytes_received_total[1m]))", "legendFormat": "recv: {{source}} → {{target}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Node / System",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Node Interface Bytes Rate",
      "description": "Per-node, per-interface IP byte rates from /proc/net. Shows total host-level traffic including non-orbit flows for context.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_node_ip_bytes_sent_total[1m])", "legendFormat": "tx: {{node}}/{{interface}}" },
        { "refId": "B", "expr": "rate(orbit_node_ip_bytes_received_total[1m])", "legendFormat": "rx: {{node}}/{{interface}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Node TCP Opens Rate",
      "description": "Rate of new TCP connections per node: active (outbound) and passive (inbound). Useful for validating connection-churn scenarios.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_node_tcp_active_opens_total[1m])", "legendFormat": "active: {{node}}" },
        { "refId": "B", "expr": "rate(orbit_node_tcp_passive_opens_total[1m])", "legendFormat": "passive: {{node}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Generator Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "title": "Generator Bytes Rate by Type",
      "description": "Bytes generated per second broken down by flow type (tcp-stream, udp-stream, http, grpc). Shows the traffic mix of the active scenario.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_generator_bytes_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Generator Errors Rate",
      "description": "Rate of errors per flow type over time. Helps isolate which protocol or generator is experiencing failures.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ]
    },
    {
      "title": "Generator Latency (p50/p95)",
      "description": "Generator-side send latency percentiles broken down by flow type. Measures the time each generator takes to complete a send operation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, flow_type) (rate(orbit_generator_latency_seconds_bucket{flow_type=~\"$flow_type\"}[$__rate_interval])))", "legendFormat": "p50 {{flow_type}}" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le, flow_type) (rate(orbit_generator_latency_seconds_bucket{flow_type=~\"$flow_type\"}[$__rate_interval])))", "legendFormat": "p95 {{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Receiver Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 67 },
      "collapsed": false
    },
    {
      "title": "Receiver Bytes Rate",
      "description": "Bytes received per second by receiver type. Should closely correlate with the corresponding Generator Bytes Rate when there is no loss.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 68 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (receiver_type) (rate(orbit_receiver_bytes_total[1m]))", "legendFormat": "{{receiver_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Receiver Connections Rate",
      "description": "Rate of new connections accepted by each receiver type. Correlates with Node TCP Opens and is key for connection-churn validation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 68 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (receiver_type) (rate(orbit_receiver_connections_total[1m]))", "legendFormat": "{{receiver_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Debugging & Errors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 76 },
      "collapsed": false
    },
    {
      "title": "Generator Errors by Reason",
      "description": "Rate of generator errors over time broken down by error reason (dial_failed, write_failed, handshake_failed, rpc_failed, etc.). Stacked view reveals the dominant failure mode.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 77 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (rate(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } } }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Error Reason Distribution",
      "description": "Proportional breakdown of generator error reasons over the selected time range. Quickly identifies which failure category dominates.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 77 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (increase(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[$__range]))", "legendFormat": "{{reason}}" }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Error Breakdown \u2014 Flow \u00d7 Reason",
      "description": "Tabular view of generator errors grouped by flow type and error reason over the last hour. Pinpoints which protocol has which failure mode.",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 77 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type, reason) (increase(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[1h]))", "legendFormat": "", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "flow_type": "Flow Type", "reason": "Reason", "Value": "Errors (1h)" } } }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Errors (1h)" }, "properties": [{ "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      }
    },
    {
      "title": "Checksum Errors by Flow Type",
      "description": "Rate of payload checksum verification failures per flow type. Non-zero rates indicate data corruption between sender and receiver.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 85 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_checksum_errors_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "DNS Resolution Latency (p50/p95)",
      "description": "DNS lookup latency percentiles. Elevated DNS times can cause dial failures and increased generator error rates.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 85 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(orbit_app_dns_resolution_seconds_bucket[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(orbit_app_dns_resolution_seconds_bucket[$__rate_interval])))", "legendFormat": "p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Connections by Flow",
      "description": "Currently open connections per flow type. Useful for verifying connection pool behavior and detecting connection leaks.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 85 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (orbit_app_connections_active{flow_type=~\"$flow_type\"})", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Generator Errors by Source Instance",
      "description": "Generator error rate broken down by source pod/instance and reason. Identifies if errors are isolated to specific nodes or widespread across the mesh.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 93 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (source, reason) (rate(orbit_generator_errors_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{source}} \u2014 {{reason}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Real-time Throughput by Flow",
      "description": "Instantaneous throughput gauge as measured by each generator. Compare with rate-based Bytes Rate panels to detect measurement divergence.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 93 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (orbit_app_throughput_bytes_per_second{flow_type=~\"$flow_type\"})", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Connection Establishment Rate",
      "description": "Rate of new TCP/gRPC connections being established per flow type. Correlate with generator errors to identify connection-establishment bottlenecks.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 101 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "sum by (flow_type) (rate(orbit_app_connections_total{flow_type=~\"$flow_type\"}[$__rate_interval]))", "legendFormat": "{{flow_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps" }
      }
    },
    {
      "title": "Node UDP Datagrams Rate",
      "description": "Kernel-level UDP datagram send/receive rates per node from /proc/net/snmp. Compare with app-level packet rates to detect drops at the OS level.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 101 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "rate(orbit_node_udp_datagrams_sent_total[1m])", "legendFormat": "sent: {{node}}" },
        { "refId": "B", "expr": "rate(orbit_node_udp_datagrams_received_total[1m])", "legendFormat": "recv: {{node}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "pps" }
      }
    }
  ],
