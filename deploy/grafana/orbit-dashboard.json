        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(orbit_app_bytes_sent_total, flow_type)",
        "hide": 0,
        "includeAll": true,
        "label": "Flow Type",
        "multi": true,
        "name": "flow_type",
        "options": [],
        "query": "label_values(orbit_app_bytes_sent_total, flow_type)",
        "refresh": 2,
